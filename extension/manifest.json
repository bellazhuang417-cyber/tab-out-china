{
  "manifest_version": 3,
  "name": "Tab Out - 国内版",
  "version": "3.0.0",
  "description": "Tab Out 国内浏览器适配版。点击图标打开标签页管理面板，按域名分组管理，支持固定快捷方式栏。",
  "permissions": ["tabs", "activeTab", "storage", "history"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out - 标签管理",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
