{
  "manifest_version": 3,
  "name": "标签收纳师",
  "version": "3.0.0",
  "description": "按网站分组管理标签页，固定常用快捷方式，智能检测重复标签。告别标签堆积，找回清爽浏览器。",
  "permissions": ["tabs", "activeTab", "storage", "history"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "标签收纳师",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
